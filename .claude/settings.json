{
  "permissions": {
    "deny": [
      "Write(../hub/**)",
      "Edit(../hub/**)",
      "Write(../script-agent/**)",
      "Edit(../script-agent/**)",
      "Write(../infra/**)",
      "Edit(../infra/**)"
    ],
    "defaultMode": "default"
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cmd.exe",
            "args": [
              "/c",
              "${CLAUDE_PROJECT_DIR}/.claude/hooks/git-bash.cmd",
              "${CLAUDE_PROJECT_DIR}/.claude/hooks/codex-gate.sh"
            ]
          }
        ]
      }
    ]
  }
}
