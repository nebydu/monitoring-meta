{
  "permissions": {
    "deny": [
      "Write(../hub/**)",
      "Edit(../hub/**)",
      "Write(../script-agent/**)",
      "Edit(../script-agent/**)",
      "Write(../infra/**)",
      "Edit(../infra/**)"
    ],
    "defaultMode": "default"
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/git-bash.cmd",
            "args": ["${CLAUDE_PROJECT_DIR}/.claude/hooks/codex-gate.sh"]
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "harness@monitoring": false
  }
}
